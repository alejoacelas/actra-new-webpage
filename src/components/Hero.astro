---
interface Props {
  heading: string;
  text: string;
  cta: string;
  learnMore: string;
  buttons: { label: string; href: string }[];
}

const { heading, text, cta, learnMore, buttons } = Astro.props;
---

<section class="w-full bg-blue text-white">
  <div class="mx-auto max-w-6xl px-6 py-16 md:py-24 lg:py-32 grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">
    <div>
      <h1 class="text-cream mb-6">{heading}</h1>
      <p class="text-lg mb-2 text-cream/90">{text}</p>
      <p class="text-lg mb-6 text-cream/90">{cta}</p>
      <p class="text-sm mb-4 text-cream/70">{learnMore}</p>
      <div class="flex flex-wrap gap-3">
        {buttons.map((btn) => (
          <a href={btn.href} target="_blank" rel="noopener" class="btn btn-primary">{btn.label}</a>
        ))}
      </div>
    </div>
    <div class="flex justify-center md:justify-end">
      <img
        src="/images/hero.jpg"
        alt="Two young men in a supportive community setting"
        class="rounded-lg max-h-[500px] object-cover w-full"
        loading="eager"
      />
    </div>
  </div>
</section>
