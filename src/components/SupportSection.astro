---
import IconFeature from "./IconFeature.astro";

interface Props {
  heading: string;
  features: { icon: string; title: string; text: string }[];
}

const { heading, features } = Astro.props;
---

<section class="w-full bg-cream py-12 md:py-20 lg:py-28">
  <div class="mx-auto max-w-6xl px-6 grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-start">
    <div>
      <h2>{heading}</h2>
    </div>
    <div class="space-y-8">
      {features.map((feature) => (
        <IconFeature icon={feature.icon} title={feature.title} text={feature.text} />
      ))}
    </div>
  </div>
</section>
