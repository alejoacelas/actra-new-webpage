---
interface Props {
  bg?: "cream" | "cream-soft" | "cream-warm" | "orange" | "blue" | "white";
  class?: string;
  id?: string;
}

const { bg = "cream", class: className = "", id } = Astro.props;

const bgMap: Record<string, string> = {
  cream: "bg-cream",
  "cream-soft": "bg-cream-soft",
  "cream-warm": "bg-cream-warm",
  orange: "bg-orange text-white",
  blue: "bg-blue text-white",
  white: "bg-white",
};
---

<section class:list={[bgMap[bg], "w-full py-12 md:py-20 lg:py-28", className]} id={id}>
  <div class="mx-auto max-w-6xl px-6">
    <slot />
  </div>
</section>
