---
interface Props {
  heading: string;
  quotes: string[];
}

const { heading, quotes } = Astro.props;
---

<section class="w-full bg-blue py-12 md:py-20">
  <div class="mx-auto max-w-6xl px-6">
    <h3 class="text-cream text-center mb-10">{heading}</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {quotes.map((quote) => (
        <div class="bg-blue-dark/30 rounded-lg p-6">
          <p class="text-cream text-sm leading-relaxed">{quote}</p>
        </div>
      ))}
    </div>
  </div>
</section>
