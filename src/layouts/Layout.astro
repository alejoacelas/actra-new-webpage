---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getLangFromUrl, getOtherLangUrl } from "../i18n/translations";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "ACTRA — Building communities where everyone feels safe" } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const otherLang = lang === "en" ? "es" : "en";
const otherLangUrl = getOtherLangUrl(Astro.url.pathname, lang);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="alternate" hreflang={otherLang} href={otherLangUrl} />
    <link rel="alternate" hreflang={lang} href={Astro.url.pathname} />
    <title>{title} | ACTRA</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
